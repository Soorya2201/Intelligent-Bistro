ANTHROPIC_API_KEY=           # required — claude-sonnet-4-6
GROQ_API_KEY=                # required — whisper-large-v3-turbo
PORT=3001
NODE_ENV=development
DB_PATH=./data/bistro.db     # SQLite file path relative to apps/api/
MAX_HISTORY_TURNS=8          # trigger summarisation after this many turns
RECOMMENDATION_COUNT=3       # items to return from /api/recommendations

# Email receipts — optional, gracefully skipped if absent
SMTP_USER=                   # Gmail address (e.g. you@gmail.com)
SMTP_PASS=                   # Gmail App Password (16-char, not your login password)
SMTP_FROM="Intelligent Bistro <noreply@bistro.app>"
